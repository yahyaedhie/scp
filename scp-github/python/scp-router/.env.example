# SCP Router — Environment Variables
# All vars use the SCP_ prefix (set in app/config.py via env_prefix="SCP_")
# Copy to .env and fill in values before running.

# Required
SCP_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional overrides (defaults shown)
SCP_ANTHROPIC_MODEL=claude-sonnet-4-6
SCP_ANTHROPIC_MAX_TOKENS=4096
SCP_DEBUG=false
SCP_DB_PATH=scp_router.db
SCP_SCP_VERSION=3.0
SCP_DEFAULT_DOMAIN=market
SCP_DRIFT_FIREWALL=true
SCP_COMPRESSION_MODE=adaptive
SCP_TOKEN_MODEL=cl100k_base
